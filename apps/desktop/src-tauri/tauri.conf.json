{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "Gravytos",
  "version": "0.1.0",
  "identifier": "com.gravytos.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5174",
    "beforeDevCommand": "cd .. && node ../../node_modules/vite/bin/vite.js --port 5174",
    "beforeBuildCommand": "cd .. && node ../../node_modules/vite/bin/vite.js build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Gravytos",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "decorations": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
